# ============================================
# AI CHAT WIDGET - CONFIGURATION
# ============================================
# Copy this file to .env and configure your settings
# cp .env.example .env

# ============================================
# AI PROVIDER (REQUIRED - choose ONE)
# ============================================
# Supports any OpenAI-compatible API

# --- OpenAI (recommended for beginners) ---
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=sk-xxx
AI_MODEL=gpt-4o-mini

# --- Claude (Anthropic) ---
# AI_BASE_URL=https://api.anthropic.com/v1
# AI_API_KEY=sk-ant-xxx
# AI_MODEL=claude-sonnet-4-20250514

# --- Google Gemini (NATIVE API - best for Russian) ---
# Uses native Gemini API, NOT OpenAI-compatible
# AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
# AI_API_KEY=AIza...
# AI_MODEL=gemini-2.0-flash-exp

# --- GigaChat (Sber, Russia) ---
# Requires special OAuth token refresh (auto-handled)
# AI_BASE_URL=https://gigachat.devices.sberbank.ru/api/v1
# AI_API_KEY=auto-refreshed
# AI_MODEL=GigaChat
# GIGACHAT_CREDENTIALS=base64_encoded_client_id:client_secret

# --- YandexGPT (Russia) ---
# AI_BASE_URL=https://llm.api.cloud.yandex.net/foundationModels/v1
# AI_API_KEY=your-api-key
# AI_MODEL=yandexgpt-lite
# YANDEX_FOLDER_ID=your-folder-id

# --- DeepSeek (China, cheap) ---
# AI_BASE_URL=https://api.deepseek.com/v1
# AI_API_KEY=sk-xxx
# AI_MODEL=deepseek-chat

# --- Qwen (Alibaba, free tier) ---
# AI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# AI_API_KEY=sk-xxx
# AI_MODEL=qwen-turbo

# --- Ollama (LOCAL, FREE) ---
# AI_BASE_URL=http://localhost:11434/v1
# AI_API_KEY=ollama
# AI_MODEL=llama3.2

# --- OpenRouter (100+ models, pay-per-use) ---
# AI_BASE_URL=https://openrouter.ai/api/v1
# AI_API_KEY=sk-or-xxx
# AI_MODEL=google/gemini-2.0-flash-exp:free

# --- LM Studio (LOCAL, FREE) ---
# AI_BASE_URL=http://localhost:1234/v1
# AI_API_KEY=lm-studio
# AI_MODEL=local-model

# ============================================
# AI SETTINGS
# ============================================
AI_TEMPERATURE=0.7
AI_MAX_TOKENS=1000

# ============================================
# STORAGE (default: json files)
# ============================================
STORAGE_TYPE=json

# SQLite (simple database)
# STORAGE_TYPE=sqlite

# PostgreSQL (production)
# STORAGE_TYPE=postgres
# DATABASE_URL=postgresql://user:password@localhost:5432/chatbot

# ============================================
# RAG / VECTOR SEARCH (optional)
# ============================================
# If zvec + sentence-transformers are available, chatbot retrieves top-k
# relevant chunks instead of injecting the full knowledge base.
ENABLE_RAG=true
RAG_TOP_K=5
RAG_CHUNK_SIZE=900
RAG_CHUNK_OVERLAP=120
RAG_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RAG_USE_ZVEC=true
RAG_FALLBACK_MAX_CHARS=12000

# ============================================
# SUPABASE LIVE DATA (optional)
# ============================================
# Used to inject up-to-date catalog/pricing/promotions into responses.
# Use service role key ONLY on backend (never in frontend).
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
# SUPABASE_TABLE_PREFIX=aftora_
# SUPABASE_TABLE_DOORS=aftora_doors
# SUPABASE_TABLE_PROMOTIONS=
# SUPABASE_TABLE_COMPANY=
# SUPABASE_CONTEXT_MAX_ITEMS=5
# SUPABASE_CACHE_TTL_SECONDS=120
# SUPABASE_TIMEOUT_SECONDS=20
# SUPABASE_SYNC_OUTPUT=knowledge/supabase-live-rag.md
# SUPABASE_SYNC_RELOAD_URL=http://localhost:8080/api/chat/knowledge/reload
# SUPABASE_SYNC_LIMIT_DOORS=200
# SUPABASE_SYNC_LIMIT_PROMOS=100
# SUPABASE_SYNC_LIMIT_COMPANY=50

# ============================================
# TELEGRAM ALERTS (optional)
# ============================================
# Get notified about:
# - User escalations (asking for human help)
# - Negative feedback
# - Positive feedback
# - Security alerts

# TELEGRAM_BOT_TOKEN=123456789:ABCdef...
# TELEGRAM_CHAT_ID=your_chat_id
# TELEGRAM_TRANSCRIPT_ENABLED=true

# ============================================
# SECURITY (optional)
# ============================================
# Rate limiting and attack detection
# MAX_MESSAGE_LENGTH=5000
# MAX_REQUESTS_PER_MINUTE=20
# MAX_REQUESTS_PER_HOUR=100
# BAN_DURATION_MINUTES=30
# MAX_STRIKES=3

# ============================================
# SERVER
# ============================================
PORT=8080
DEBUG=false
CORS_ORIGINS=*
# CORS_ORIGINS=https://example.com,https://app.example.com
